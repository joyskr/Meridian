{
  "name": "meridian",
  "private": true,
  "version": "0.1.0",
  "description": "Meridian monorepo bootstrap",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "pg-mem": "^3.0.5",
    "prettier": "^3.5.3",
    "supertest": "^7.1.1",
    "typescript-eslint": "^8.33.1"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @meridian/web",
    "dev:api": "npm run dev --workspace @meridian/api",
    "dev:worker": "npm run dev --workspace @meridian/worker",
    "build": "npm run build --workspace @meridian/api && npm run build --workspace @meridian/web && npm run build --workspace @meridian/worker && npm run build --workspace @meridian/contracts",
    "lint": "node scripts/lint.mjs",
    "test": "npm run test:unit && npm run test:integration && npm run test:contract && npm run test:security && npm run test:e2e",
    "test:unit": "node scripts/run-tsx-tests.mjs tests/unit",
    "test:integration": "node scripts/run-tsx-tests.mjs tests/integration",
    "test:contract": "node scripts/run-tsx-tests.mjs tests/contract",
    "test:security": "node scripts/run-tsx-tests.mjs tests/security",
    "test:e2e": "node scripts/run-tsx-tests.mjs tests/e2e",
    "typecheck": "node scripts/typecheck.mjs",
    "verify:bootstrap": "node scripts/verify-bootstrap.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  }
}
